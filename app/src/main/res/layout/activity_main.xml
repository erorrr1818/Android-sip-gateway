<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:scrollbarStyle="outsideOverlay"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- ═══════ HEADER ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="18dp">

            <!-- Brand nick -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="dber88"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GSM · SIP · GATEWAY"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.20"
                android:layout_marginTop="2dp"/>

            <!-- Thin cyan divider -->
            <View
                android:layout_width="80dp"
                android:layout_height="1dp"
                android:background="@color/brand_primary"
                android:layout_marginTop="12dp"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- ═══════ STATUS CARD ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INITIALIZING..."
                android:background="@drawable/bg_status_off"
                android:padding="10dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSIONS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/permissionsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:background="@drawable/bg_input"
                android:padding="8dp"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- ═══════ CONNECT BUTTONS ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/connectButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▶  CONNECT"
                android:background="@drawable/btn_primary"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="■  STOP"
                android:background="@drawable/btn_danger"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.08"/>

        </LinearLayout>

        <!-- ═══════ SIP CONFIG CARD ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIP CONFIGURATION"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <!-- Server + Port row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/sipServer"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="2"
                    android:hint="SIP Server / IP"
                    android:inputType="textNoSuggestions"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/sipPort"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:hint="5060"
                    android:inputType="number"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <!-- Username + Password row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/sipUser"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:hint="Username"
                    android:inputType="textNoSuggestions"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/sipPassword"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <!-- Realm -->
            <EditText
                android:id="@+id/sipRealm"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:hint="Realm (leave * for any)"
                android:inputType="textNoSuggestions"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:padding="10dp"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- TLS toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/useTls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/brand_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use TLS encryption (port 5061)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- SIM routing -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GSM → SIP ROUTING"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/sim1Destination"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:hint="SIM1 → ext (e.g. 101)"
                    android:inputType="textNoSuggestions"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <EditText
                    android:id="@+id/sim2Destination"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:hint="SIM2 → ext (optional)"
                    android:inputType="textNoSuggestions"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leave SIM2 empty for single-SIM device"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- Incoming call mode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INCOMING CALL MODE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/incomingModeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/modeSipFirst"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SIP first → answer GSM when connected"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_primary"
                    android:textSize="12sp"/>

                <RadioButton
                    android:id="@+id/modeAnswerFirst"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Answer GSM → connect SIP"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_primary"
                    android:textSize="12sp"/>
            </RadioGroup>

            <!-- Save button -->
            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="💾  SAVE SIP SETTINGS"
                android:background="@drawable/btn_save"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:letterSpacing="0.05"/>

        </LinearLayout>

        <!-- ═══════ BATTERY CARD ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BATTERY MANAGEMENT"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop charging at specified level to preserve battery (requires root)"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/batteryLimitRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/limit60"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="60% (recommended)"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_green"
                    android:textSize="12sp"/>

                <RadioButton
                    android:id="@+id/limit100"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="100% (no limit)"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_yellow"
                    android:textSize="12sp"/>
            </RadioGroup>
        </LinearLayout>

        <!-- ═══════ AUDIO CONFIG CARD ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIO CONFIGURATION"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qualcomm: capture=VOC_REC_DL, playback=Incall_Music"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp"/>

            <!-- Sound Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOUND CARD"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/cardSpinner"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:spinnerMode="dialog"
                android:layout_marginBottom="10dp"/>

            <!-- Capture Device -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAPTURE DEVICE (GSM→SIP)"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/captureSpinner"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:spinnerMode="dialog"
                android:prompt="@string/select_capture"
                android:layout_marginBottom="10dp"/>

            <!-- Playback Device -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYBACK DEVICE (SIP→GSM)"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/playbackSpinner"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:spinnerMode="dialog"
                android:prompt="@string/select_playback"
                android:layout_marginBottom="10dp"/>

            <!-- Mixer Route -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIXER ROUTE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/mixerRouteSpinner"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:spinnerMode="dialog"
                android:prompt="@string/select_mixer"
                android:layout_marginBottom="12dp"/>

            <!-- Audio Gain row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIO GAIN (dB)"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TX  GSM→SIP"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="2dp"/>

                    <EditText
                        android:id="@+id/txGainEdit"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:inputType="numberDecimal|numberSigned"
                        android:hint="0"
                        android:background="@drawable/bg_input"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:padding="10dp"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RX  SIP→GSM"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="2dp"/>

                    <EditText
                        android:id="@+id/rxGainEdit"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:inputType="numberDecimal|numberSigned"
                        android:hint="0"
                        android:background="@drawable/bg_input"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:padding="10dp"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Device Mute Preset -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVICE MUTE PRESET"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mutes speaker/mic on gateway during calls (enforced every 3s)"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/devicePresetSpinner"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="8dp"/>

            <!-- Custom mute controls (hidden by default) -->
            <LinearLayout
                android:id="@+id/customMuteContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DETECTED MIXER CONTROLS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/micMuteCheckboxContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MANUAL CONTROLS (comma-separated)"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/manualMuteControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. DEC1 Volume, EAR_S, ADC1 MUX"
                    android:inputType="text"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:padding="10dp"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="'Volume' → INT→0   Others → ENUM→ZERO"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Audio Save + Restart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/saveAudioButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="2"
                    android:text="💾  SAVE AUDIO"
                    android:background="@drawable/btn_save"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/restartButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="↺ RESTART"
                    android:background="@drawable/btn_ghost"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold"
                    android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ═══════ WEB INTERFACE CARD ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_accent"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEB INTERFACE"
                android:textColor="@color/brand_accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Switch
                    android:id="@+id/webInterfaceSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/brand_accent"
                    android:trackTint="@color/bg_card2"/>

                <TextView
                    android:id="@+id/webInterfaceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open browser config on port 8080"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════ FOOTER ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp">

            <View
                android:layout_width="80dp"
                android:layout_height="1dp"
                android:background="@color/brand_primary"
                android:alpha="0.2"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
