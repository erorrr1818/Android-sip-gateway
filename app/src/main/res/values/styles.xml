<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base dark theme -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:colorPrimary">@color/brand_primary</item>
        <item name="android:colorPrimaryDark">@color/bg_dark</item>
        <item name="android:colorAccent">@color/brand_accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="colorControlNormal">@color/brand_primary</item>
        <item name="colorControlActivated">@color/brand_primary</item>
        <item name="colorControlHighlight">@color/brand_primary</item>
    </style>

    <!-- Card section style -->
    <style name="CardSection">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">14dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <!-- Section header label -->
    <style name="SectionLabel">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Input field style -->
    <style name="InputField">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:padding">10dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Primary button -->
    <style name="ButtonPrimary">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">10dp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Danger button -->
    <style name="ButtonDanger">
        <item name="android:background">@drawable/btn_danger</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- Ghost button -->
    <style name="ButtonGhost">
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">10dp</item>
    </style>

</resources>
